# Programming Languages
GITOXIDE_CORE_MULTIPACKINDEX=true
NODE_NO_WARNINGS=1
NEXT_TELEMETRY_DISABLED=1

# Wine / Proton
WINEFSYNC=1
WINEESYNC=1
DXVK_ASYNC=1
PULSE_LATENCY_MSEC=60
WINE_FULLSCREEN_FSR=1
VKD3D_CONFIG=dxr,dxr11
PROTON_ENABLE_WAYLAND=1
PROTON_USE_NTSYNC=1
PROTON_HIDE_NVIDIA_GPU=0
PROTON_ENABLE_NVAPI=1
PROTON_DXVK_GPLASYNC=1
PROTON_DLSS_UPGRADE=1
PROTON_LOG=0
QT_ENABLE_HIGHDPI_SCALING=1
QT_AUTO_SCREEN_SCALE_FACTOR=1
MESA_DEBUG=0
MESA_NO_ERROR=1
MESA_NO_DITHER=1

# OpenGL / NVIDIA
__GL_SHADER_DISK_CACHE=1
__GL_SHADER_DISK_CACHE_SKIP_CLEANUP=1
__GL_SHADER_DISK_CACHE_SIZE=12000000000
__GL_THREADED_OPTIMIZATIONS=1
__GL_SORT_FBCONFIGS=1
__GL_IGNORE_GLSL_EXT_REQS=1
__GL_ALLOW_UNSUPPORTED_PLATFORM=1
__GL_ALLOW_UNOFFICIAL_PROTOCOL=1
__GL_SYNC_TO_VBLANK=0
GPU_USE_SYNC_OBJECTS=1

# Video / compositor
GST_VAAPI_ALL_DRIVERS=1
QSG_NO_VSYNC=1
KWIN_TRIPLE_BUFFER=0
KWIN_DRM_NO_AMS=0
KWIN_USE_OVERLAYS=1
VK_LOADER_DEBUG=none
ELECTRON_OZONE_PLATFORM_HINT=auto
SDL_VIDEO_MINIMIZE_ON_FOCUS_LOSS=0

MIMALLOC_ALLOW_LARGE_OS_PAGES=1
SYSTEMD_SERVICE_FILE_WATCHERS=disabled

# Privacy
DOTNET_CLI_TELEMETRY_OPTOUT=1
POWERSHELL_TELEMETRY_OPTOUT=1
DISABLE_TELEMETRY=1
DO_NOT_TRACK=1
DISABLE_ERROR_REPORTING=1
NEXT_TELEMETRY_DISABLED=1

ELECTRON_DISABLE_SANDBOX=1
