#!/usr/bin/env bash
set -euo pipefail

has() { command -v -- "$1" &>/dev/null; }
die() { printf '\e[31mERROR: %s\e[0m\n' "$*" >&2; exit 1; }

[[ $# -eq 0 ]] && die "At least 1 argument required!"

has pkexec || die "pkexec is required but not installed."

# Use pkexec to run the command with graphical environment variables preserved
pkexec env \
  DISPLAY="${DISPLAY:-}" \
  XAUTHORITY="${XAUTHORITY:-}" \
  "$@"
