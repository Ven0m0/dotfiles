font-family = JetBrainsMono Nerd Font
font-size = 12
font-feature = ss01,ss02,ss03,ss04,ss05,ss06,ss07,ss08,ss09,ss10,ss19,ss20,calt,lig,liga,dlig,clig,zero

cursor-style = bar
cursor-style-blink = true
window-theme = dark
window-subtitle = false
window-decoration = true
window-padding-balance = true
window-inherit-working-directory = true
working-directory = home
background-opacity = 1.00
theme = TokyoNight Night

shell-integration = detect
shell-integration-features = cursor,no-sudo,ssh-env,ssh-terminfo

custom-shader-animation = false
app-notifications = config-reload,no-clipboard-copy

mouse-hide-while-typing = true
mouse-scroll-multiplier = 2.5
scrollback-limit = 5000
confirm-close-surface = false

clipboard-read = allow
clipboard-write = allow
clipboard-paste-protection = false
clipboard-trim-trailing-spaces = true
copy-on-select = clipboard

keybind = alt+k=new_tab
keybind = alt+shift+q=toggle_quick_terminal
keybind = alt+z=reload_config
keybind = shift+enter=text:\x1b\r
keybind = home=scroll_to_top
keybind = end=scroll_to_bottom
keybind = shift+insert=paste_from_clipboard
keybind = control+insert=copy_to_clipboard
keybind = alt+shift+arrow_down=new_split:down
keybind = alt+shift+arrow_up=new_split:up
keybind = alt+shift+arrow_left=new_split:left
keybind = alt+shift+arrow_right=new_split:right
keybind = alt+ctrl=goto_split
keybind = alt+ctrl+x=equalize_splits

keybind = ctrl+v=paste_from_clipboard
keybind = ctrl+c=copy_to_clipboard
keybind = ctrl+z=undo
keybind = ctrl+shift+z=redo
